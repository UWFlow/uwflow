# --- ClickHouse (events analytics store) ---
# Host is the compose service name; the container is internal-only (no host port).
# CLICKHOUSE_PORT is the native TCP protocol port used by clickhouse-go/v2.
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=flow_events
CLICKHOUSE_PASSWORD=secretinprod
# Salt mixed into sha256(client_ip + salt) so we never store raw IPs.
# MUST be set to a long random value in staging/prod; rotating it unlinks history.
EVENTS_IP_HASH_SALT=change-me-to-a-long-random-string
